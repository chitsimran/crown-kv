# Copy this file to setup/.env and fill in values for your environment.

# Required: VM SSH user.
SSH_USER=ritwikg3

# Required: repository to clone on the VMs.
REPO_URL=https://github.com/YOUR_ORG/crown-kv.git
REPO_BRANCH=main

# Remote checkout location. Defaults to /home/$SSH_USER when omitted.
REMOTE_BASE_DIR=/home
REPO_NAME=crown-kv
PROJECT_SUBDIR=.

# Cluster runtime defaults.
PROTOCOL_MODE=CROWN
METADATA_HOST=sp26-cs525-1201.cs.illinois.edu
METADATA_PORT=50050
NODE_BIND_HOST=0.0.0.0
NODE_PORT=50051
CLIENT_ACK_PORT=6000

# Optional SSH key for reaching the VMs.
# SSH_KEY_LOCAL=~/.ssh/id_ed25519

# Shared tmux socket and run directory scope.
TMUX_SOCKET=/tmp/crown-shared/tmux.sock
RUN_SCOPE=shared
BUILD_TYPE=Release
